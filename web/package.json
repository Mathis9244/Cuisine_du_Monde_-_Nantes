{
  "name": "cuisine-du-monde-web",
  "version": "1.0.0",
  "private": true,
  "description": "Cuisine du Monde - Nantes : application full-stack Next.js (front + API) connectée à Supabase",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "node scripts/generate-pwa-icons.mjs && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.100.0",
    "framer-motion": "^12.26.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.562.0",
    "next": "^15.5.0",
    "next-pwa": "^5.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.0",
    "postcss": "^8.4.49",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
