{
  "name": "cuisine-du-monde-web",
  "version": "1.0.0",
  "private": true,
  "description": "Circle : application full-stack Next.js (front + API) connectée à Supabase",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "node scripts/generate-pwa-icons.mjs && next build && node scripts/copy-public-to-standalone.mjs",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.100.0",
    "framer-motion": "^12.26.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.562.0",
    "next": "^16.2.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "overrides": {
    "postcss": "^8.5.15"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.0",
    "postcss": "^8.5.15",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
