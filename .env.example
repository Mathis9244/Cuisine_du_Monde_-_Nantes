# ---- Supabase (DB + Auth) ----
# Exposé au navigateur (lecture + auth côté client)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Clé service role : SERVEUR UNIQUEMENT (jamais NEXT_PUBLIC_*).
# Utilisée par les Route Handlers admin pour écrire en base.
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# URL publique du site (pour sitemap/robots + canonical). Optionnel en dev.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Rôle considéré comme admin (dans app_metadata.role ou user_metadata.role de Supabase)
ADMIN_ROLE="admin"

# ---- CI/CD (GitHub Actions) ----
# Optionnel : définir ces variables dans Settings → Secrets and variables → Actions → Variables
# pour embarquer la vraie config Supabase dans l'image Docker publiée sur ghcr.io.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SITE_URL=

GEMINI_API_KEY=""
