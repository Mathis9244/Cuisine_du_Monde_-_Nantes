# Base de données PostgreSQL
DATABASE_URL="postgresql://cuisine:cuisine@localhost:5433/cuisine_du_monde"

# JWT pour l'authentification admin
JWT_SECRET="changez-moi-en-production-minimum-32-caracteres"

# Port du serveur (optionnel, défaut 3001)
PORT=3001

# Supabase
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
ENABLE_STARTUP_IMPORT="false"
SUPABASE_IMPORT_TABLE="restaurants"
SUPABASE_IMPORT_MARKER_TABLE="startup_import_runs"

# Commande du scraper Selenium Google Maps (JSON stdout requis)
# Le wrapper intégré utilise le repo cloné dans backend/scripts/Selenium_cuisine_du_monde.
# Dépendances Python minimales:
#   pip install selenium webdriver-manager psycopg2-binary
GOOGLE_SCRAPER_COMMAND="python scripts/google_maps_scraper.py --city Nantes --limit 5 --headless"
